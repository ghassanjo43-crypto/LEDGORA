node_modules
dist
dist-ssr
*.local
.vite

# Local environment / secrets — NEVER commit. `.env.local` carries the
# VITE_LEDGORA_DEV_TOOLS opt-in that enables local platform-admin tooling.
.env
.env.*
!.env.example

# Editor
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Backend runtime artefacts.
# These patterns are ANCHORED with a leading slash on purpose. An unanchored
# `storage/` matches a directory of that name at any depth, which silently
# excluded the `server/src/storage/` SOURCE directory from commits and broke the
# deploy build. Only the runtime upload directories belong here.
/server/dist/
/server/storage/
/storage/
