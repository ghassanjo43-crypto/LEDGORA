# LEDGORA frontend configuration.
# Copy to `.env.local` (git-ignored) for local development.
#
# ⚠ Every VITE_ variable is inlined into the PUBLIC browser bundle.
#   Never put a password, session secret, database URL or API key here.

# Public URL of the LEDGORA backend API. Not a secret.
# Render example: https://ledgora-api.onrender.com
VITE_API_URL=http://localhost:3000

# Local-only developer tooling (edition switcher, simulated platform role).
# Takes effect ONLY together with import.meta.env.DEV, i.e. under `npm run dev`.
# A production build has the whole path statically disabled, so this can never
# grant administrator access on a deployed site.
VITE_LEDGORA_DEV_TOOLS=false
