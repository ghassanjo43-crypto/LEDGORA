# LEDGORA local development configuration.
#
# Copy to `.env.local` (which is git-ignored) to enable platform-administration
# tooling on your own machine:
#
#   VITE_LEDGORA_DEV_TOOLS=true
#
# This ONLY takes effect together with `import.meta.env.DEV`, i.e. under
# `npm run dev`. A production bundle built with `npm run build` has the whole
# administration path statically disabled, so this value cannot enable
# administrator actions on a deployed site. Never put a secret in a VITE_*
# variable — everything prefixed VITE_ is inlined into the public bundle.
VITE_LEDGORA_DEV_TOOLS=false
