# LEDGORA frontend configuration.
# Copy to `.env.local` (git-ignored) for local development.
#
# ⚠ Every VITE_ variable is inlined into the PUBLIC browser bundle.
#   Never put a password, session secret, database URL or API key here.

# Where the browser sends API calls. Not a secret (it is inlined into the
# bundle). Two supported shapes:
#
#  1. SAME-ORIGIN PROXY (recommended). Point this at the FRONTEND's own origin;
#     a `/api` reverse proxy (render.yaml, or the Vite dev proxy) forwards to the
#     API. The session cookie is then a genuine same-origin cookie.
#       production: https://ledgora-frontend.onrender.com
#       local dev : http://localhost:5173   (Vite proxies /api → :3000)
#
#  2. CROSS-SITE (only if the browser must talk to the API host directly). Point
#     this at the API origin, and set COOKIE_SAMESITE=none on the server.
#       https://ledgora-api.onrender.com
#
# Leave empty to build the static demo (browser-only auth, no backend).
VITE_API_URL=http://localhost:5173

# Local-only developer tooling (edition switcher, simulated platform role).
# Takes effect ONLY together with import.meta.env.DEV, i.e. under `npm run dev`.
# A production build has the whole path statically disabled, so this can never
# grant administrator access on a deployed site.
VITE_LEDGORA_DEV_TOOLS=false
