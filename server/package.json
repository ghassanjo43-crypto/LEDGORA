{
  "name": "@ledgora/server",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "LEDGORA backend API — authentication, platform roles, subscriptions and audit",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate": "tsx src/cli/migrate.ts up",
    "db:migrate:down": "tsx src/cli/migrate.ts down",
    "create-platform-admin": "tsx src/cli/createPlatformAdmin.ts"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/multipart": "^10.1.0",
    "@fastify/rate-limit": "^10.2.2",
    "@node-rs/argon2": "^2.0.2",
    "fastify": "^5.2.1",
    "kysely": "^0.27.5",
    "pg": "^8.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.10"
  }
}
