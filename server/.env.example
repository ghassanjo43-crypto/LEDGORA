# LEDGORA backend configuration.
# Copy to `server/.env` (git-ignored) for local development.
# NEVER commit real values. Nothing here belongs in a VITE_ variable — those are
# inlined into the public frontend bundle.

NODE_ENV=development
PORT=3000
# Render sets PORT itself; the server always binds 0.0.0.0.
HOST=0.0.0.0

# PostgreSQL connection string.
# Leave EMPTY in local development to use the in-process PGlite database
# (real PostgreSQL, nothing to install, not persisted). Required in production.
DATABASE_URL=

# Exact origin(s) allowed to make credentialed requests. Comma-separated.
# Production example: https://ledgora.onrender.com
FRONTEND_URL=http://localhost:5173

# Long random string. Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# The server refuses to start in production while this is the default.
SESSION_SECRET=replace-me
SESSION_TTL_HOURS=24
PASSWORD_RESET_TTL_MINUTES=30

# Payment-proof storage (local development adapter).
UPLOAD_DIRECTORY=./storage/payment-proofs
MAX_UPLOAD_BYTES=5242880

# Set true only when running behind Render's proxy, so client IPs are correct.
TRUST_PROXY=false

# Login protection.
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
ACCOUNT_LOCK_THRESHOLD=8
ACCOUNT_LOCK_MINUTES=15

# ── First-administrator bootstrap ────────────────────────────────────────────
# For the initial Render deploy only, where no terminal is available.
# Prefer `npm run create-platform-admin` for everyday administration.
# Enable, deploy once, then REMOVE the password and set ENABLED back to false.
BOOTSTRAP_ADMIN_ENABLED=false
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_FULL_NAME=
